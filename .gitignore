# Unreal Engine generated folders
Binaries/
DerivedDataCache/
Intermediate/
Saved/
Build/
Platforms/*/Binaries/
Platforms/*/Intermediate/

# Plugin build artifacts
Plugins/**/Binaries/
Plugins/**/Intermediate/

# IDE / project files
.vs/
.vscode/
.idea/
*.sln
*.suo
*.xcodeproj/
*.xcworkspace/
*.VC.db
*.VC.opendb
*.opensdf
*.sdf

# OS junk
Desktop.ini
.DS_Store
Thumbs.db

# Crash dumps / logs
*.log
*.pdb

# Keep these tracked explicitly:
#   *.uproject, Config/, Source/, Plugins/**/Source/, Plugins/**/Shaders/,
#   Plugins/**/*.uplugin, Content/ (if any), Docs/

# Large / third-party demo assets — intentionally NOT committed (repo size, no LFS,
# AI-generated provenance). The committed LV_Demo uses the box soft body; assign any
# Static Mesh to SoftBody->SourceMesh to reproduce mesh embedding. See HANDOFF "DEMO ASSET NOTE".
/Content/tripo_convert_*.uasset
/Content/tripo_mat_*.uasset
/Content/cute_bunny_3d_model_*.uasset

# More large / third-party test imports (SB-M8 DF-collision testing) — kept out of the repo.
/Content/MilkDragons.uasset
/Content/plate1.uasset
/Content/M_Plate.uasset
/Content/*_3d_model_*.uasset
/Content/_GENERATED/
